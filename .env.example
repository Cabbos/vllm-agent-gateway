# Required model settings
MODEL_PATH=/absolute/path/to/your/model
SERVED_MODEL=local-model
MODEL_CONTEXT_LENGTH=32768

# vLLM runtime
VLLM_IMAGE=vllm/vllm-openai:v0.25.0
GPU_MEMORY_UTILIZATION=0.90
MAX_NUM_SEQS=2
MAX_NUM_BATCHED_TOKENS=4096
# Parser names are model-specific. Examples: qwen3 / qwen3_coder, deepseek_r1 / hermes.
REASONING_PARSER=
TOOL_CALL_PARSER=hermes

# Gateway
VLLM_UPSTREAM=http://vllm:8001
GATEWAY_PORT=8000
# Empty disables application-layer authentication. Set a comma-separated list in production.
GATEWAY_API_KEYS=change-me
GATEWAY_CORS_ORIGINS=*
GATEWAY_TRUSTED_HOSTS=*
GATEWAY_MAX_REQUEST_BYTES=67108864

# Model metadata exposed to Ollama/Gemini clients
MODEL_FAMILY=local
MODEL_PARAMETER_SIZE=unknown
MODEL_QUANTIZATION=unknown
MODEL_FORMAT=safetensors
MODEL_SIZE_BYTES=0
MODEL_VRAM_BYTES=0

# Document compatibility limits
PDF_COMPAT_MAX_BYTES=52428800
PDF_COMPAT_MAX_PAGES=64
PDF_COMPAT_MAX_RENDERED_PAGES=24
PDF_COMPAT_MAX_CHARS=500000
