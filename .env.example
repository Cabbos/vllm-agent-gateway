# Required by Docker Compose: absolute host path to a local model directory.
MODEL_PATH=/absolute/path/to/your/model
SERVED_MODEL=local-model
MODEL_CONTEXT_LENGTH=32768

# vLLM container runtime. The 2-sequence profile is a conservative starting
# point for a single 32 GiB GPU; use 1 for long-context memory pressure.
VLLM_IMAGE=vllm/vllm-openai:v0.25.0
GPU_MEMORY_UTILIZATION=0.90
MAX_NUM_SEQS=2
MAX_NUM_BATCHED_TOKENS=4096
# Parser names are model-specific, for example qwen3, qwen3_coder, or hermes.
TOOL_CALL_PARSER=hermes

# Gateway and upstream authentication. Keep these credentials different.
# Compose overrides VLLM_UPSTREAM with the private vllm service URL.
VLLM_UPSTREAM=http://vllm:8001
VLLM_UPSTREAM_API_KEY=
GATEWAY_PORT=8000
# Empty disables application-layer authentication. Never leave empty on a
# shared network. Multiple keys are comma-separated.
GATEWAY_API_KEYS=change-me
GATEWAY_CORS_ORIGINS=*
GATEWAY_TRUSTED_HOSTS=*

# Request admission. 74099371 bytes is the derived default for a 50 MiB PDF:
# base64 expansion plus 4 MiB for JSON, prompts, tools, and other fields.
GATEWAY_MAX_REQUEST_BYTES=74099371
# Recommended single-32-GiB-GPU starting point. Set MAX_INFLIGHT=0 to disable.
GATEWAY_MAX_INFLIGHT=2
GATEWAY_MAX_QUEUE_SIZE=8
GATEWAY_QUEUE_TIMEOUT_SECONDS=30
# Set a positive RPM to enable the per-key in-process token bucket.
GATEWAY_REQUESTS_PER_MINUTE=0
GATEWAY_RATE_LIMIT_BURST=10
GATEWAY_METRICS_ENABLED=true

# Upstream connection pool. Streaming responses intentionally have no total
# response timeout; only the connection timeout is bounded here.
UPSTREAM_CONNECT_TIMEOUT=10
UPSTREAM_MAX_CONNECTIONS=100
UPSTREAM_MAX_KEEPALIVE_CONNECTIONS=20

# Model metadata exposed to Ollama/Gemini clients.
MODEL_FAMILY=local
MODEL_PARAMETER_SIZE=unknown
MODEL_QUANTIZATION=unknown
MODEL_FORMAT=safetensors
MODEL_SIZE_BYTES=0
MODEL_VRAM_BYTES=0

# Document resource limits.
PDF_COMPAT_MAX_BYTES=52428800
PDF_COMPAT_MAX_PAGES=64
PDF_COMPAT_MAX_RENDERED_PAGES=24
PDF_COMPAT_MAX_CHARS=500000
PDF_MAX_PAGE_PIXELS=16000000
PDF_CONVERSION_CONCURRENCY=2
PDF_CONVERSION_TIMEOUT_SECONDS=60

# Remote PDF/plain-text URLs are disabled by default. To opt in, set policy to
# allowlist and list exact hosts or *.subdomain patterns. Private or benchmark
# IP ranges also require an explicit CIDR in EXTRA_ALLOWED_NETWORKS.
DOCUMENT_URL_POLICY=deny
DOCUMENT_ALLOWED_HOSTS=
DOCUMENT_EXTRA_ALLOWED_NETWORKS=
